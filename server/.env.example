###############################################################################
# ThinkAiSolutions — SERVER environment (Express + TypeScript)
#
# Copy this file to `.env` (in the /server directory) and fill in real values.
# The server validates these at boot with zod (config/env.ts). REQUIRED vars
# throw at startup in production; in development they may be empty and the app
# boots with a warning so you can iterate without full credentials.
#
# SECURITY: This file documents shape only — NEVER commit a real `.env`.
# The Meta App Secret + System User token, the Razorpay secret, Firebase admin
# creds, and the secrets encryption key live ONLY on the server and must never
# reach the frontend.
###############################################################################

# ---------------------------------------------------------------------------
# Core HTTP server
# ---------------------------------------------------------------------------

# Port the Express server listens on. Railway injects its own PORT in prod.
PORT=8080

# Runtime mode: 'development' | 'production' | 'test'. Controls validation
# strictness (REQUIRED vars are enforced when NODE_ENV=production) and error
# verbosity (internals are never leaked in production responses).
NODE_ENV=development

# Allowed browser origin for CORS (the deployed console URL). Used by
# cors({ origin: CORS_ORIGIN, credentials: true }).
# Dev default is the Vite dev server. Prod example: https://console.thinkaisolutions.com
CORS_ORIGIN=http://localhost:5173

# Public, internet-reachable base URL of THIS server. The Meta webhook callback URL you
# register in the Meta App is PUBLIC_BASE_URL/api/webhooks/meta. Dev default assumes local;
# in prod set the Cloud Run URL or custom domain. Example (prod): https://api.thinkaisolutions.com
PUBLIC_BASE_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# Firebase Admin (Firestore + Auth)  — REQUIRED in production
# Service-account credentials. Create a service account in the Firebase console
# (Project Settings -> Service accounts -> Generate new private key) and copy
# the three fields below out of the downloaded JSON.
# ---------------------------------------------------------------------------

# Firebase / GCP project id (e.g. thinkaisolutions-prod).
FIREBASE_PROJECT_ID=

# Service-account client email (e.g. firebase-adminsdk-xxxxx@<project>.iam.gserviceaccount.com).
FIREBASE_CLIENT_EMAIL=

# Service-account private key. Keep the surrounding quotes and the literal "\n"
# escapes on ONE line — the server replaces each "\n" with a real newline at boot.
# Example:
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANB...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# ---------------------------------------------------------------------------
# WhatsApp provider selection
# All provider calls are isolated behind services/bsp; this picks the active backend.
# ---------------------------------------------------------------------------

# Active provider. metaCloud (direct Meta WhatsApp Cloud API) is the sole provider.
BSP_PROVIDER=metaCloud

# Per-request timeout (ms) for outbound Graph calls (metaCloud's graphFetch AbortController).
BSP_HTTP_TIMEOUT_MS=15000

# ---------------------------------------------------------------------------
# Meta WhatsApp Cloud API (direct Tech Provider) — the ACTIVE backend.
#
# META_MODE decides which credentials are needed:
#   test -> run against Meta's TEST number with just App id/secret + the test number's temporary
#           token + a verify token. System User token + Config id are OPTIONAL (the server boots
#           without them). Default in development.
#   live -> full production: System User token + Embedded Signup Config id are REQUIRED.
#           Default in production.
# ---------------------------------------------------------------------------

# 'test' | 'live'. Keep 'test' until business verification + App Review are done.   [test + live]
META_MODE=test

# Meta App id (public; also handed to the browser to launch Embedded Signup).        [test + live]
META_APP_ID=

# Meta App Secret — verifies the X-Hub-Signature-256 webhook HMAC. SERVER-ONLY.      [test + live]
META_APP_SECRET=

# TEST-MODE Bearer: the Meta test number's temporary access token (WhatsApp > API Setup).
# Rotates ~24h — update this value and restart when it expires.                      [test only]
META_TEST_ACCESS_TOKEN=

# Token YOU choose for the webhook GET handshake. Set the SAME value as the Verify Token in the
# Meta App webhook config; we echo hub.challenge only when it matches.               [test + live]
META_WEBHOOK_VERIFY_TOKEN=

# LIVE-ONLY: Meta System User access token — the Bearer for ALL Graph calls in live mode.
# SERVER-ONLY; inject from a secret manager. Leave blank in test mode.               [live only]
META_SYSTEM_USER_TOKEN=

# LIVE-ONLY: Embedded Signup configuration id (needs App Review). Leave blank in test mode.
#                                                                                    [live only]
META_CONFIG_ID=

# Graph API version. Optional: defaults to the shared constant META_GRAPH_VERSION in
# shared/src/constants.ts (the client uses the same, so they can't drift). Override for a hotfix.
META_GRAPH_VERSION=

# ---------------------------------------------------------------------------
# Self-serve signup — default per-category CHARGE rates (integer paise)
# Auto-seeded onto a new self-serve tenant's pricing/{tenantId} so they can send after a
# wallet recharge. Optional (dev defaults below); SET NON-ZERO IN PRODUCTION — zero would
# mean free messaging for self-serve tenants. The reseller-admin create flow does NOT use
# these (the admin sets rates in the wizard).
# ---------------------------------------------------------------------------
SIGNUP_DEFAULT_MARKETING_PAISE=90
SIGNUP_DEFAULT_UTILITY_PAISE=35
SIGNUP_DEFAULT_AUTH_PAISE=35

# ---------------------------------------------------------------------------
# Developer Hub — client-facing webhook forwarding (2.5)
# We forward clean, HMAC-signed platform events to each tenant's own callback URL via a
# background delivery worker (the slow HTTP POST never touches the Meta webhook 200 path).
# ---------------------------------------------------------------------------

# Hard timeout (ms) for each POST to a tenant's callback URL. Optional (default 10000).
WEBHOOK_DELIVERY_TIMEOUT_MS=10000

# Set to 'true' on web-only instances to skip starting the in-process delivery worker (mirrors
# CAMPAIGN_WORKER_DISABLED). Leave unset so the worker runs and drains the delivery queue.
# WEBHOOK_DELIVERY_WORKER_DISABLED=true

# ---------------------------------------------------------------------------
# Secret store (where BSP apikeys + webhook secrets live)
# Firestore docs only ever store an opaque REFERENCE, never the plaintext secret.
# ---------------------------------------------------------------------------

# Driver selecting the SecretStore implementation: 'firestore' | 'env'.
#   firestore -> AES-256-GCM encrypted secrets in the locked-down 'secrets' collection.
#   env       -> read secrets straight from process.env (dev/static use).
SECRET_STORE_DRIVER=firestore

# 32-byte symmetric key (hex or base64) for AES-256-GCM when SECRET_STORE_DRIVER=firestore.
# REQUIRED in production. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SECRETS_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Razorpay (wallet recharge) — REQUIRED in production
# From the Razorpay Dashboard. KEY_ID is the only one safe to expose to the
# client; KEY_SECRET and WEBHOOK_SECRET stay server-side.
# ---------------------------------------------------------------------------

# Razorpay key id (rzp_test_xxx / rzp_live_xxx). Same value goes in the client's
# VITE_RAZORPAY_KEY_ID (it is public — used to open Checkout).
RAZORPAY_KEY_ID=

# Razorpay key secret — used to create orders. NEVER expose to the client.
RAZORPAY_KEY_SECRET=

# Razorpay webhook secret — set this same value in the Razorpay Dashboard webhook
# config. We verify payment.captured via HMAC-SHA256(rawBody, this) (constant-time).
RAZORPAY_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# GST / invoicing (seller details)
# Used to decide CGST+SGST (intra-state) vs IGST (inter-state) on recharge invoices.
# Both optional: if neither the buyer state nor SELLER_STATE resolves, invoices
# fall back to a single 'unspecified' GST line and log a warning.
# ---------------------------------------------------------------------------

# Our (seller) 15-char GSTIN (e.g. 36ABCDE1234F1Z5). Optional.
SELLER_GSTIN=

# Our (seller) GST state code, 2 digits 01–37 or 97. Telangana = 36. Optional.
# When set, it drives the intra-state vs inter-state tax split.
SELLER_STATE=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# pino log level: 'fatal' | 'error' | 'warn' | 'info' | 'debug' | 'trace'.
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Bootstrap (runbook step 0 — one-time reseller-admin seeding)
# Optional: used by `npm run bootstrap:admin` (scripts/bootstrap-admin.ts) if you
# prefer env over argv. The script finds/creates this Auth user, grants the
# reseller_admin role (tenantId null), and writes users/{uid}.
# ---------------------------------------------------------------------------
BOOTSTRAP_ADMIN_EMAIL=
