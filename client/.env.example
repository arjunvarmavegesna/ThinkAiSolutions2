###############################################################################
# ThinkAiSolutions — CLIENT environment (React + Vite)
#
# Copy this file to `.env` (in the /client directory) and fill in real values.
# Only Vite vars prefixed with VITE_ are exposed to the browser bundle.
#
# IMPORTANT: EVERYTHING here is PUBLIC — it ships inside the JS bundle. Put NO
# secrets here. The Firebase web API key and the Razorpay key id below are NOT
# secrets (Firebase access is gated by Auth + Firestore rules; the Razorpay key
# id only opens Checkout). Server-only secrets (the Meta App Secret + System User
# token, Razorpay key secret, Firebase admin creds) live exclusively in /server/.env.
#
# NOTE: Meta Embedded Signup needs NO client env var. The browser fetches the public
# Meta App id / Config id / Graph version from the server (GET /api/admin/onboarding/config)
# at launch time — a single server-side source of truth, so server + client never drift.
#
# lib/config.ts validates these at startup and fails fast if a required one is missing.
###############################################################################

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------

# Base URL the client uses for all API calls (apiClient.ts). In dev the Vite
# proxy forwards '/api' -> http://localhost:8080, so the default works locally.
# In production set this to the deployed server URL, e.g.
#   https://api.thinkaisolutions.com/api
VITE_API_BASE_URL=/api

# ---------------------------------------------------------------------------
# Firebase Web SDK (public client config)
# From the Firebase console: Project Settings -> General -> Your apps -> Web app
# -> SDK setup and configuration. These are safe to expose; access is enforced
# by Firebase Auth + Firestore security rules, and the client never reads
# Firestore directly (it talks only to the Express API).
# ---------------------------------------------------------------------------

# Firebase web API key (e.g. AIzaSy...).
VITE_FIREBASE_API_KEY=

# Auth domain (e.g. thinkaisolutions-prod.firebaseapp.com).
VITE_FIREBASE_AUTH_DOMAIN=

# Firebase project id (e.g. thinkaisolutions-prod). Must match the server's
# FIREBASE_PROJECT_ID so ID tokens verify.
VITE_FIREBASE_PROJECT_ID=

# Storage bucket (e.g. thinkaisolutions-prod.appspot.com).
VITE_FIREBASE_STORAGE_BUCKET=

# Cloud Messaging sender id (numeric).
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Firebase app id (e.g. 1:1234567890:web:abcdef123456).
VITE_FIREBASE_APP_ID=

# ---------------------------------------------------------------------------
# Razorpay (Checkout)
# ---------------------------------------------------------------------------

# Public Razorpay key id (rzp_test_xxx / rzp_live_xxx) used to open the Razorpay
# Checkout widget. Must equal the server's RAZORPAY_KEY_ID. This is public — the
# Razorpay key SECRET stays server-side only.
VITE_RAZORPAY_KEY_ID=
